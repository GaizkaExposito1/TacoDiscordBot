# Configuración para el Bot de Pruebas
# Copia esto en un archivo llamado .env.test y rellena con los datos del bot de pruebas

DISCORD_TOKEN=TOKEN_DEL_BOT_DE_PRUEBAS
CLIENT_ID=ID_CLIENTE_DEL_BOT_DE_PRUEBAS
GUILD_ID=ID_DEL_SERVIDOR_DE_PRUEBAS

# Indicador de entorno de desarrollo (importante para el prefijo 'd')
NODE_ENV=development
