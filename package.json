{
  "name": "taco-managment",
  "version": "1.4.0",
  "description": "Sistema integral de gestión de comunidades: Moderación avanzada, Auditoría, Sugerencias y Tickets.",
  "main": "src/index.js",
  "scripts": {
    "start": "node src/index.js",
    "deploy": "node deploy-commands.js",
